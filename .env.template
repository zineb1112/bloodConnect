# .env.template (DO NOT RENAME TO .env AND COMMIT)

#--- Hajar: this file helps you define your own .env files that should respect this and later 
# on if you add a env var mention it here so that we weill be aligned---

# -----------------
# 1. DATABASE CONFIG (Used by all services in docker-compose)
# -----------------
POSTGRES_DB=bloodconnect_db
POSTGRES_USER=blood_user
POSTGRES_PASSWORD=your_secure_db_password_here
# Note: DB_HOST is set internally in docker-compose to 'db'

# -----------------
# 2. APPLICATION SECRETS
# -----------------
# Generate a long, random key for each Django service
HOSPITAL_SECRET_KEY=generate_long_random_string_for_hospital
DONOR_SECRET_KEY=generate_long_random_string_for_donor

# -----------------
# 3. SERVICE HOSTS (Used by Django settings to connect to gRPC)
# -----------------
# AI_SERVICE_TARGET is used by the Hospital backend to reach the AI service
AI_SERVICE_TARGET=ai:50051

# DONOR_SERVICE_TARGET is used by the Hospital backend to reach the Donor backend (e.g., for data sync)
DONOR_SERVICE_TARGET=donor:8000